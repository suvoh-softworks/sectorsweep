;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sector Sweep - J.A.C.K."
config/description="A fast-paced tactical shooter. Move fast and use a wide variety of weapons and tools to stop SUNSET Company's plans before it's too late."
run/main_scene="uid://bflu68ff2p76f"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://15lcun2uanvk"

[autoload]

Managers="*uid://swkjm5eullty"

[editor_plugins]

enabled=PackedStringArray("res://addons/func_godot/plugin.cfg", "res://addons/godot_state_charts/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "red",
"res://assets/": "orange",
"res://assets/scripts/": "orange",
"res://levels/": "yellow",
"res://map_editor/": "green",
"res://scenes/": "teal"
}

[func_godot]

model_point_class_save_path="red://map_editor/models"

[global_group]

Player=""
Managers=""

[godot_vmf]

import/gameinfo_path="/home/wilhelm/.steam/steam/steamapps/common/Source SDK Base 2013 Singleplayer/sectorsweep/gameinfo.txt"
import/instances_folder="res://sdk/instances"
import/entities_folder="res://sdk/entities"
import/geometry_folder="res://sdk/geometry"
materials/default_texture_size=128

[gui]

common/quality/screen_space_aa=0
common/quality/msaa_3d=1
common/quality/msaa_2d=1

